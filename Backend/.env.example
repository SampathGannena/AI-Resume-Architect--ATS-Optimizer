# Server
PORT=3000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/careerforge
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# Auth (minimum 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=12h

# Signed asset URLs (minimum 32 characters)
PDF_SIGNING_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
PDF_SIGNED_URL_TTL_SEC=900

# PDF queue + worker (MongoDB-backed queue worker)
PDF_PIPELINE_ENABLED=false
PDF_WORKER_INLINE=false
PDF_WORKER_POLL_TIMEOUT_SEC=5
PDF_QUEUE_KEY=careerforge:pdf:jobs
PDF_QUEUE_POLL_INTERVAL_MS=350
PDF_QUEUE_STALE_PROCESSING_MS=900000
PDF_QUEUE_STALE_REQUEUE_BATCH_SIZE=50

# Object storage (AWS S3 or S3-compatible)
OBJECT_STORAGE_BUCKET=careerforge-pdfs
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
PDF_OBJECT_PREFIX=careerforge/pdfs
PDF_STORAGE_MONGO_FALLBACK=true
PDF_STORAGE_MONGO_MIRROR_ON_S3_SUCCESS=false

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# AI guardrails
AI_RATE_LIMIT_MAX=100
AI_TIMEOUT_MS=12000
RESUME_PDF_MAX_MB=5

# Optional Groq rewrite provider
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT_MS=9000

# Optional Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
